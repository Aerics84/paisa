{
  "name": "paisa",
  "version": "0.0.1",
  "private": true,
  "packageManager": "npm@11.6.2",
  "engines": {
    "node": "24.x",
    "npm": "11.x"
  },
  "scripts": {
    "prepare": "node --input-type=module -e \"import { existsSync } from 'node:fs'; if (existsSync('./scripts/setup-git-hooks.mjs')) await import('./scripts/setup-git-hooks.mjs');\"",
    "sync-version": "node scripts/sync-version.mjs",
    "test:imports": "bun test --preload ./src/happydom.ts src/lib/import.test.ts",
    "test:regression": "bun test tests/regression.test.ts",
    "test:prepush": "node ./scripts/preflight-critical.mjs",
    "check:format:changed": "node ./scripts/prettier-changed.mjs",
    "check:format:staged": "node ./scripts/prettier-changed.mjs --staged",
    "format:changed": "node ./scripts/prettier-changed.mjs --write",
    "format:staged": "node ./scripts/prettier-changed.mjs --write --staged --restage --fail-on-partial-staging",
    "check:format:all": "prettier --check .",
    "format:all": "prettier --write .",
    "parser-build": "lezer-generator src/lib/sheet/language.grammar -o src/lib/sheet/parser && lezer-generator src/lib/search/parser/query.grammar -o src/lib/search/parser/parser",
    "parser-build-debug": "lezer-generator src/lib/sheet/language.grammar --names -o src/lib/sheet/parser && lezer-generator src/lib/search/parser/query.grammar --names -o src/lib/search/parser/parser",
    "dev": "vite dev --host 0.0.0.0",
    "build": "vite build",
    "build:watch": "vite build --watch",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --compiler-warnings 'a11y-aria-attributes:ignore,a11y-incorrect-aria-attribute-type:ignore,a11y-unknown-aria-attribute:ignore,a11y-hidden:ignore,a11y-misplaced-role:ignore,a11y-unknown-role:ignore,a11y-no-abstract-role:ignore,a11y-no-redundant-roles:ignore,a11y-role-has-required-aria-props:ignore,a11y-accesskey:ignore,a11y-autofocus:ignore,a11y-misplaced-scope:ignore,a11y-positive-tabindex:ignore,a11y-invalid-attribute:ignore,a11y-missing-attribute:ignore,a11y-img-redundant-alt:ignore,a11y-label-has-associated-control:ignore,a11y-media-has-caption:ignore,a11y-distracting-elements:ignore,a11y-structure:ignore,a11y-mouse-events-have-key-events:ignore,a11y-missing-content:ignore,a11y-click-events-have-key-events:ignore,a11y-no-static-element-interactions:ignore'",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch --compiler-warnings 'a11y-aria-attributes:ignore,a11y-incorrect-aria-attribute-type:ignore,a11y-unknown-aria-attribute:ignore,a11y-hidden:ignore,a11y-misplaced-role:ignore,a11y-unknown-role:ignore,a11y-no-abstract-role:ignore,a11y-no-redundant-roles:ignore,a11y-role-has-required-aria-props:ignore,a11y-accesskey:ignore,a11y-autofocus:ignore,a11y-misplaced-scope:ignore,a11y-positive-tabindex:ignore,a11y-invalid-attribute:ignore,a11y-missing-attribute:ignore,a11y-img-redundant-alt:ignore,a11y-label-has-associated-control:ignore,a11y-media-has-caption:ignore,a11y-distracting-elements:ignore,a11y-structure:ignore,a11y-mouse-events-have-key-events:ignore,a11y-missing-content:ignore,a11y-click-events-have-key-events:ignore,a11y-no-static-element-interactions:ignore'",
    "lint": "npm run check:format:all && eslint .",
    "format": "npm run format:all"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.1",
    "@datasert/cronjs-matcher": "^1.2.0",
    "@datasert/cronjs-parser": "^1.2.0",
    "@egjs/svelte-grid": "^1.18.0",
    "@fontsource-variable/roboto-flex": "^5.2.8",
    "@fontsource-variable/roboto-mono": "^5.2.8",
    "@formatjs/intl-numberformat": "^8.15.6",
    "@fortawesome/fontawesome-free": "^6.7.2",
    "@lezer/highlight": "^1.2.3",
    "@lezer/lr": "^1.4.10",
    "@types/json-schema": "^7.0.12",
    "arima": "^0.2.8",
    "bignumber.js": "^9.3.1",
    "bulma": "^1.0.4",
    "bulma-toast": "^2.4.4",
    "chroma-js": "^2.6.0",
    "chrono-node": "^2.9.0",
    "clipboard": "^2.0.11",
    "codemirror": "^6.0.2",
    "compute-cosine-similarity": "^1.0.0",
    "crypto-js": "^4.2.0",
    "d3": "^7.9.0",
    "d3-delaunay": "^6.0.2",
    "d3-path-arrows": "^0.4.0",
    "d3-sankey-circular": "^0.34.0",
    "dayjs": "^1.11.20",
    "financial": "^0.1.3",
    "handlebars": "^4.7.9",
    "lodash": "^4.18.1",
    "papaparse": "^5.5.3",
    "pdfjs-dist": "^5.7.284",
    "sprintf-js": "^1.1.2",
    "stemmer": "^2.0.1",
    "svelte-carousel": "^1.0.25",
    "svelte-file-dropzone": "^2.0.9",
    "svelte-local-storage-store": "^0.6.0",
    "svelte-select": "^5.8.3",
    "svelte-tiny-virtual-list": "^2.0.5",
    "tabulator-tables": "^6.4.0",
    "textures": "^1.2.3",
    "tippy.js": "^6.3.7",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.19.3/xlsx-0.19.3.tgz",
    "xlsx-populate": "^1.21.0"
  },
  "devDependencies": {
    "@codemirror/merge": "^6.12.1",
    "@happy-dom/global-registrator": "^17.6.3",
    "@iconify/json": "^2.2.467",
    "@iconify/tools": "^5.0.11",
    "@lezer/generator": "^1.8.0",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.58.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/chroma-js": "^2.4.5",
    "@types/crypto-js": "^4.2.2",
    "@types/d3": "^7.4.0",
    "@types/json-diff": "^1.0.3",
    "@types/lodash": "^4.17.24",
    "@types/papaparse": "^5.5.2",
    "@types/sprintf-js": "^1.1.2",
    "@types/tabulator-tables": "^5.32.1",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "axios": "^1.15.2",
    "bun-types": "^1.3.13",
    "concurrently": "^7.6.0",
    "daisyui": "^5.5.19",
    "date-picker-svelte": "^2.17.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^8.10.2",
    "eslint-plugin-svelte": "^2.46.1",
    "json-diff": "^1.0.6",
    "nodemon": "^3.1.14",
    "oslllo-svg-fixer": "^3.0.0",
    "postcss": "^8.5.12",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.1",
    "sass": "^1.99.0",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.6",
    "svelte-dnd-action": "^0.9.69",
    "svg2ttf": "^6.0.3",
    "svgicons2svgfont": "^16.0.0",
    "tailwindcss": "^4.2.4",
    "tslib": "^2.8.1",
    "ttf2woff2": "^8.0.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.10",
    "wait-port": "^1.1.0"
  },
  "overrides": {
    "canvas": "3.2.0"
  },
  "type": "module"
}
